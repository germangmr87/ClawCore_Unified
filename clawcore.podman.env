# ClawCore Podman environment
# Copy to clawcore.podman.env.local and set CLAWCORE_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   CLAWCORE_PODMAN_ENV=/path/to/clawcore.podman.env ./scripts/run-clawcore-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-clawcore-podman.sh which can generate it).
CLAWCORE_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
CLAWCORE_PODMAN_GATEWAY_HOST_PORT=18789
CLAWCORE_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
CLAWCORE_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
